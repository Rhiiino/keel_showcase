# keel_web/.gitignore

# OS metadata
.DS_Store
Thumbs.db

# Editor and local workspace files
.vscode/
.idea/
*.swp
*.swo

# Local environment and secrets
.env
.env.*

# Logs and runtime output
*.log
logs/
tmp/
temp/

# Dependency caches
node_modules/
.npm/
.pnpm-store/

# Build artifacts
dist/
build/
coverage/
*.tsbuildinfo

# Vite prebundle cache
.vite/

package-lock.json